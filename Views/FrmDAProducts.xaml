<Window x:Class="WpfApp5.Views.FrmDAProducts"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp5.Views"
        WindowStartupLocation="CenterOwner"
        xmlns:vm="clr-namespace:WpfApp5.ViewModels"
        Title="Data Analysis: Products" Height="600" Width="800">

    <Window.DataContext>
        <vm:FrmDAProductsVM/>
    </Window.DataContext>

    <Window.Resources>
        <CollectionViewSource x:Key="GroupedProducts"
                          Source="{Binding Products}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="ProductGroupDisplay" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.4*"/>
            <RowDefinition Height="3.2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
            <TextBlock Text="{Binding TxtKeywordLbl}" FontSize="12" FontWeight="Bold" Margin="5" Height="20"/>
            <!--<Border BorderBrush="Black" BorderThickness="1" Height="20">-->
            <TextBox Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Width="200" Height="20"/>
            <!--</Border>-->
            <Button Command="{Binding SearchCommand}" Margin="5,5,0,5" Width="20" Height="20">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE721;" FontSize="12" TextAlignment="Center"/>
            </Button>
            <Button Command="{Binding ClearSearchCommand}" Margin="5" Width="20" Height="20">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" FontSize="12" TextAlignment="Center"/>
            </Button>
            <Button Command="{Binding FakeTranslateCommand}" Margin="5" Padding="5,0,5,0" Height="20">
                <TextBlock FontFamily="Arial" Text="Translate (fake)" FontSize="10" TextAlignment="Center"/>
            </Button>
        </StackPanel>

        <Grid Margin="10" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Grid.IsSharedSizeScope="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="*"/>
                    <!-- List -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="5,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ColProductName"/>
                        <ColumnDefinition Width="20"/>
                        <!-- spacer, optional -->
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ColPrice"/>
                        <ColumnDefinition Width="Auto"/>
                        <!-- optional: actions column -->
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding ProductLblCapt}" FontWeight="Bold" FontSize="{Binding HeaderLblFntSize}"/>
                    <TextBlock Grid.Column="2" Text="Price" FontWeight="Bold"/>
                </Grid>

                <!-- Items -->
                <ListView Grid.Row="1" ItemsSource="{Binding ProductsView}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="ColProductName"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="ColPrice"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- actions -->
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                     Text="{Binding ProductName}"
                                     MinWidth="120"
                                     TextWrapping="NoWrap" />

                                <TextBox Grid.Column="2"
                                     Text="{Binding ProductPrice}"
                                     MinWidth="80" />

                                <Button Grid.Column="3" Width="25" Height="25"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
            
            <ListView Grid.Row="1" ItemsSource="{Binding ProductsView}"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"  Margin="0,10,0,0">
                <!-- Group Header -->
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Border Height="1"
                                Background="Gray"
                                Margin="0,0,0,0"/>
                                    <!-- Group Label -->
                                    <TextBlock Text="{Binding Name}"
                               FontWeight="Bold"
                               FontSize="14"
                               Padding="4"/>

                                    <!-- Line Under Label -->
                                    <Border Height="1"
                            Background="Gray"
                            Margin="0,0,0,8"/>
                                </StackPanel>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="{Binding DataContext.ProductLblCapt, RelativeSource={RelativeSource AncestorType=ListView}}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ProductID}" />
                                <TextBlock Text=" - " FontWeight="Bold"/>
                                <TextBlock Text="{Binding ProductName}" />
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="1" Orientation="Vertical">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Current stock : "/>
                                        <TextBlock Text="{Binding ProductQty, StringFormat={}{0:F0}}" />
                                        <TextBlock Text=" "/>
                                        <TextBlock Text="{Binding ProductUnit}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Current price : "/>
                                        <TextBlock Text="{Binding ProductPrice, StringFormat='IDR {0:N2}'}" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Delete Button -->
                                <Button Grid.Column="2" Height="25" Width="25"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}" Margin="5,0,0,0">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="16" TextAlignment="Center"/>
                                </Button>
                            </Grid>

                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Command="{Binding PrintRdlcV3Command}" Margin="5" Height="30" Width="100" Content="Print Report v4"/>
            <Button Command="{Binding Export2PDFCommand}" Margin="5" Height="30" Width="100" Content="Export to PDF"/>
            <Button Command="{Binding PrintRdlcV2Command}" Margin="5" Height="30" Width="100" Content="Print Report v3"/>
            <Button Command="{Binding PrintRdlcCommand}" Margin="5" Height="30" Width="100" Content="Print Report v2"/>
            <Button Command="{Binding PrintCommand}" Margin="5" Height="30" Width="100" Content="Print Report"/>
            <Button Click="CloseButton_Click" Margin="5" Height="30" Width="100" Content="Close"/>
        </StackPanel>
    </Grid>
</Window> 
